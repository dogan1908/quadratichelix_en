% ──Quasi Polynome──────────────────────────────────────────────────────

@book{BeckRobins2007,
  author    = {Beck, Matthias and Robins, Sinai},
  title     = {Computing the Continuous Discretely:
               Integer-Point Enumeration in Polyhedra},
  publisher = {Springer},
  year      = {2007},
  isbn      = {978-0-387-29139-0},
  note      = {Frei verfügbar: \url{https://matthbeck.github.io/ccd.html}},
  annotation = {Zugänglichste Einführung in Ehrhart-Quasi-Polynome (Kap.~3--4).
    Die oszillierende Parabel $f(n) = \frac{1}{4}(12n^2-6n+(-1)^n(4n-1)+1)$
    ist ein Quasi-Polynom der Periode~2 im Sinne von Ehrhart -- die
    $(-1)^n$-Korrektur codiert den Wechsel zwischen den Kongruenzklassen
    $n \equiv 1,5\pmod{6}$.}
}

