% ── Gewöhnliche Differentialgleichungen ───────────────────────────────────────

@book{Teschl2012,
  author    = {Teschl, Gerald},
  title     = {Ordinary Differential Equations and Dynamical Systems},
  series    = {Graduate Studies in Mathematics},
  volume    = {140},
  publisher = {American Mathematical Society},
  address   = {Providence, RI},
  year      = {2012},
  isbn      = {978-0-8218-8328-0},
  note      = {Frei verfügbar: \url{https://www.mat.univie.ac.at/~gerald/ftp/book-ode/}},
  annotation = {Belegt Eindeutigkeitssatz und Trennung der Variablen (Kap.~2),
    die Grundlage von Satz~\ref{satz:ode}: Die ODE $(4z+3)\,dz/dk = 6$
    mit Anfangsbedingung $z(1/6)=0$ besitzt eine eindeutige Lösung, die
    exakt mit der invertierten Folgengleichung $k(z)=k$ übereinstimmt.
    Die Originalität liegt in der Verbindung zur Folgenstruktur, nicht
    in der ODE-Lösung selbst.}
}

