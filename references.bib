% ── Zahlentheorie ─────────────────────────────────────────────────────────────

@book{Hardy2008,
  author    = {Hardy, Godfrey Harold and Wright, Edward Maitland},
  title     = {An Introduction to the Theory of Numbers},
  edition   = {6},
  editor    = {Heath-Brown, D. R. and Silverman, J. H.},
  publisher = {Oxford University Press},
  address   = {Oxford},
  year      = {2008},
  isbn      = {978-0-19-921986-5},
  annotation = {Standardreferenz für quadratische Formen (Kap.~14--15) und
    die Darstellung von Zahlen durch Quadrate (Kap.~20). Liefert den
    zahlentheoretischen Rahmen für die Fundamentalidentität
    $(4n+3)^2 = 48\,k(n)+1$: Das Polynom $k(n)$ erzeugt an ganzzahligen
    Stellen stets vollständige Quadrate -- eine Eigenschaft, die im Kontext
    binärer quadratischer Formen und quadratischer Felder behandelt wird.}
}

@misc{OEIS,
  author       = {Sloane, Neil J. A. and {OEIS Foundation Inc.}},
  title        = {The {On-Line Encyclopedia of Integer Sequences}},
  howpublished = {\url{https://oeis.org}},
  year         = {2024},
  annotation   = {Standarddatenbank für ganzzahlige Folgen. Relevant für die
    Folge $k(n) = (2n^2+3n+1)/6$ sowie die universelle Größe $Q(n) = 4n+3$.
    Ein OEIS-Eintrag macht die Folge für andere Forscher auffindbar und
    erlaubt systematische Querverbindungen zu verwandten Sequenzen.}
}

% ── Phyllotaxis und Spiralgitter ───────────────────────────────────────────────

@book{Jean1994,
  author    = {Jean, Roger V.},
  title     = {Phyllotaxis: A Systemic Study in Plant Morphogenesis},
  publisher = {Cambridge University Press},
  address   = {Cambridge},
  year      = {1994},
  isbn      = {978-0-521-40482-2},
  annotation = {Maßgebliche mathematische Referenz für äquidistante Punkte auf
    Archimedischen Spiralen und die daraus entstehenden ganzzahligen Gitterstrukturen
    (Parastichien). Die Strahlenstruktur in Kap.~\ref{sec:visualisierung} --
    Diagonalen entlang $n \equiv 1,5\pmod{6}$ -- ist das arithmetische Analogon
    der Parastichien-Spiralen. Kap.~4--6 behandeln quadratische Wachstumsgesetze
    auf Spiralen systematisch und belegen den allgemeinen Werkzeugcharakter der
    asymptotischen Methode.}
}

