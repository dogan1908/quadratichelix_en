% ── Erdős–Shapiro 1955: Distribution function of the Euler error term ─

@article{ErdosShapiro1955,
  author    = {Erd\H{o}s, Paul and Shapiro, Harold N.},
  title     = {The existence of a distribution function for an error term
               related to the {E}uler function},
  journal   = {Canadian Journal of Mathematics},
  volume    = {7},
  pages     = {63--75},
  year      = {1955},
  doi       = {10.4153/CJM-1955-009-3},
  mrnumber  = {MR16,448f},
  annotation = {Proof that the error function
    $H(x) = \sum_{n \leqslant x}\varphi(n)/n - 6x/\pi^2$ possesses
    a continuous distribution function. The constant $6/\pi^2$ is
    identical to the spiral constant~$a$ of the present work. The
    paper uses the continuity of the distribution function of
    $\varphi(n)/n$ (Erd\H{o}s--Wintner 1939) as a key step.}
}

